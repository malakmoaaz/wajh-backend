{
  "name": "wajh-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "WAJH Clinical CDSS — Express/PostgreSQL backend",
  "main": "wajh-backend/src/server.js",
  "scripts": {
    "postinstall": "npx prisma generate",
    "dev": "nodemon wajh-backend/src/server.js",
    "start": "node wajh-backend/src/server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:seed": "node src/seed.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.14.0"
  }
}
